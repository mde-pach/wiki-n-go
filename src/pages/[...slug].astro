---
import Appearance from "../components/Appearance.tsx";
import Infobox from "../components/Infobox.tsx";
import Toc from "../components/Toc.tsx";
import TocMobile from "../components/TocMobile.tsx";
import WikiPage from "../components/WikiPage.tsx";
import { config } from "../config";
import PageShell from "../layouts/PageShell.astro";
import { decorateHeadingsHtml, emphasizeLeadHtml, parsePage } from "../lib/markdown";
import { contentSlugs, rawPage } from "../lib/pages";
import {
  BASE,
  contentSlugForRoute,
  isLangHome,
  langOf,
  prettify,
  readHref,
  slugifyPath,
} from "../lib/paths";
import { markRedLinksHtml } from "../lib/wikilink";

export function getStaticPaths() {
  return [
    { params: { slug: undefined } },
    ...contentSlugs()
      .filter((s) => s !== config.homeSlug)
      .map((s) => ({ params: { slug: isLangHome(s) ?? s } })),
  ];
}

const { slug } = Astro.params;
const pageSlug = contentSlugForRoute(slug);

const raw = rawPage(pageSlug);
const parsed = raw ? parsePage(raw) : null;
const html = parsed
  ? emphasizeLeadHtml(
      decorateHeadingsHtml(
        markRedLinksHtml(parsed.html, new Set(contentSlugs()), langOf(pageSlug)),
        pageSlug,
      ),
      parsed.title,
    )
  : undefined;

const redirectTo = parsed?.meta?.redirect ? slugifyPath(parsed.meta.redirect) : null;
const redirectUrl =
  redirectTo && redirectTo !== pageSlug
    ? `${readHref(redirectTo)}?redirectedfrom=${encodeURIComponent(pageSlug)}`
    : null;
---

<PageShell slug={pageSlug} view="read" title={parsed?.title || prettify(pageSlug)} categories={parsed?.meta?.tags} description={parsed?.meta?.description}>
  {
    redirectUrl && (
      <script
        is:inline
        set:html={`if(!/[?&]redirect=no/.test(location.search))location.replace(${JSON.stringify(redirectUrl)})`}
      />
    )
  }
  <main id="main" class="read-grid">
    <div class="col-toc">
      <Toc editHref={`${BASE}/edit/${pageSlug}`} initialItems={parsed?.headings ?? []} client:load />
    </div>
    <div class="col-main">
      <TocMobile initialItems={parsed?.headings ?? []} client:load />
      <Infobox slug={pageSlug} meta={parsed?.meta} client:load />
      <WikiPage slug={pageSlug} initialHtml={html} initialRaw={raw} meta={parsed?.meta} client:load />
    </div>
    <div class="col-info">
      <Appearance client:load />
    </div>
  </main>
</PageShell>
