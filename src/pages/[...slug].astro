---
import Appearance from "../components/Appearance.tsx";
import Contributions from "../components/Contributions.tsx";
import CurationBoot from "../components/CurationBoot.astro";
import PageCuration from "../components/PageCuration.tsx";
import Toc from "../components/Toc.tsx";
import TocMobile from "../components/TocMobile.tsx";
import WikiPage from "../components/WikiPage.tsx";
import { config } from "../config";
import PageShell from "../layouts/PageShell.astro";
import { fetchMarkdown, PageNotFoundError } from "../lib/content";
import { decorateArticleHtml, parsePage } from "../lib/markdown";
import { contentSlugs, rawPage } from "../lib/pages";
import {
  BASE,
  contentSlugForRoute,
  isLangHome,
  prettify,
  readHref,
  slugifyPath,
  userLogin,
  viewHref,
} from "../lib/paths";
import { fetchPageSlugs, pageNoindex } from "../lib/ssr";

// Prerendered (static) build only — ignored when EDGE_SSR makes this route
// on demand (see astro.config.mjs). The edge path resolves any slug at request
// time, so it needs no path list.
export function getStaticPaths() {
  return [
    { params: { slug: undefined } },
    ...contentSlugs()
      .filter((s) => s !== config.homeSlug)
      .map((s) => ({ params: { slug: isLangHome(s) ?? s } })),
  ];
}

const { slug } = Astro.params;
const pageSlug = contentSlugForRoute(slug);

// Static path: render from the build-time content glob. Edge-SSR path: fetch the
// latest content + slug set from the CDN/Worker at request time (no rebuild).
// The decorate + render pipeline below is identical for both.
const ssr = !Astro.isPrerendered;
let raw: string | undefined;
let slugs: Set<string>;
if (ssr) {
  slugs = await fetchPageSlugs();
  try {
    raw = await fetchMarkdown(pageSlug);
  } catch (err) {
    if (err instanceof PageNotFoundError) raw = undefined;
    else raw = rawPage(pageSlug); // transient fetch error → build-time fallback
  }
} else {
  raw = rawPage(pageSlug);
  slugs = new Set(contentSlugs());
}

const parsed = raw ? parsePage(raw) : null;
const html = parsed
  ? decorateArticleHtml(parsed.html, slugs, pageSlug, parsed.title)
  : undefined;

const redirectTo = parsed?.meta?.redirect ? slugifyPath(parsed.meta.redirect) : null;
const redirectUrl =
  redirectTo && redirectTo !== pageSlug
    ? `${readHref(redirectTo)}?redirectedfrom=${encodeURIComponent(pageSlug)}`
    : null;

// On the edge path, finish request-time concerns before rendering: a real
// server-side redirect for crawlers, a 404 status for missing pages, a real
// noindex-until-patrolled, and a short edge cache (request-time fresh, so the
// client island skips its refetch — no double-fetch).
let noindex = false;
if (ssr) {
  if (redirectUrl && Astro.url.searchParams.get("redirect") !== "no") {
    return Astro.redirect(redirectUrl, 301);
  }
  if (!parsed) Astro.response.status = 404;
  noindex = parsed ? await pageNoindex(pageSlug) : true;
  Astro.response.headers.set(
    "Cache-Control",
    "public, max-age=0, s-maxage=30, stale-while-revalidate=600",
  );
}

// A built `user/<login>` page also gets the auto-rendered contributions panel.
const profileLogin = userLogin(pageSlug);
const contributor =
  profileLogin && !profileLogin.startsWith("anon-") ? profileLogin : null;
---

<PageShell slug={pageSlug} view="read" title={parsed?.title || prettify(pageSlug)} categories={parsed?.meta?.tags} description={parsed?.meta?.description} appearance={parsed?.meta?.appearance} ssr={ssr} noindex={noindex} titlePending={!ssr}>
  {
    redirectUrl && (
      <script
        is:inline
        set:html={`if(!/[?&]redirect=no/.test(location.search))location.replace(${JSON.stringify(redirectUrl)})`}
      />
    )
  }
  <main id="main" class="read-grid">
    <div class="col-toc">
      <Toc editHref={viewHref("edit", pageSlug)} initialItems={ssr ? (parsed?.headings ?? []) : []} client:load />
    </div>
    <div class="col-main">
      <TocMobile initialItems={ssr ? (parsed?.headings ?? []) : []} client:load />
      <CurationBoot />
      <PageCuration slug={pageSlug} bar client:idle />
      <WikiPage slug={pageSlug} initialHtml={ssr ? html : undefined} initialRaw={ssr ? raw : undefined} meta={ssr ? parsed?.meta : undefined} fresh={ssr} missing={ssr && !parsed} client:load />
      {contributor && <Contributions login={contributor} client:load />}
    </div>
    <div class="col-info">
      <Appearance client:idle />
    </div>
  </main>
</PageShell>
