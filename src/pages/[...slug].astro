---
import Appearance from "../components/Appearance.tsx";
import Contributions from "../components/Contributions.tsx";
import CurationBoot from "../components/CurationBoot.astro";
import PageCuration from "../components/PageCuration.tsx";
import Toc from "../components/Toc.tsx";
import TocMobile from "../components/TocMobile.tsx";
import WikiPage from "../components/WikiPage.tsx";
import { config } from "../config";
import PageShell from "../layouts/PageShell.astro";
import { gitBlobSha } from "../lib/blobsha";
import { decorateArticleHtml, parsePage } from "../lib/markdown";
import { contentSlugs, rawPage } from "../lib/pages";
import {
  BASE,
  contentSlugForRoute,
  isAnonName,
  isLangHome,
  prettify,
  readHref,
  slugifyPath,
  userLogin,
  viewHref,
} from "../lib/paths";

// Static (prerendered) output: one route per page in the build-time content glob.
export function getStaticPaths() {
  return [
    { params: { slug: undefined } },
    ...contentSlugs()
      .filter((s) => s !== config.homeSlug)
      .map((s) => ({ params: { slug: isLangHome(s) ?? s } })),
  ];
}

const { slug } = Astro.params;
const pageSlug = contentSlugForRoute(slug);

// Render from the build-time glob. The rendered HTML is baked into a <noscript>
// below (real content for non-JS crawlers); `bakedSha` is the page's git blob sha,
// which the island compares against the live per-page sha to decide whether the
// baked copy is still current (paint it) or stale (fetch from the CDN).
const raw = rawPage(pageSlug);
const slugs = new Set(contentSlugs());
const parsed = raw ? parsePage(raw) : null;
const html = parsed
  ? decorateArticleHtml(parsed.html, slugs, pageSlug, parsed.title)
  : undefined;
const bakedSha = raw ? gitBlobSha(raw) : undefined;

const redirectTo = parsed?.meta?.redirect ? slugifyPath(parsed.meta.redirect) : null;
const redirectUrl =
  redirectTo && redirectTo !== pageSlug
    ? `${readHref(redirectTo)}?redirectedfrom=${encodeURIComponent(pageSlug)}`
    : null;

// A built `user/<login>` page also gets the auto-rendered contributions panel.
const profileLogin = userLogin(pageSlug);
const contributor = profileLogin && !isAnonName(profileLogin) ? profileLogin : null;

// A profile's title is "User: <login>", known from the slug — render it final
// (never the slug/frontmatter title the client would otherwise fill in, which
// would blink), and tell its WikiPage the title is already owned.
const profileTitle = profileLogin ? `User: ${profileLogin}` : null;
const displayTitle = profileTitle ?? (parsed?.title || prettify(pageSlug));
---

<PageShell slug={pageSlug} view="read" title={displayTitle} categories={parsed?.meta?.tags} description={parsed?.meta?.description} appearance={parsed?.meta?.appearance} titlePending={!profileTitle}>
  {
    redirectUrl && (
      <script
        is:inline
        set:html={`if(!/[?&]redirect=no/.test(location.search))location.replace(${JSON.stringify(redirectUrl)})`}
      />
    )
  }
  <main id="main" class="read-grid">
    <div class="col-toc">
      <Toc editHref={viewHref("edit", pageSlug)} initialItems={[]} client:load />
    </div>
    <div class="col-main">
      <TocMobile initialItems={[]} client:load />
      <CurationBoot />
      <PageCuration slug={pageSlug} bar client:idle />
      {html && <noscript id="wiki-baked" set:html={html} />}
      <WikiPage slug={pageSlug} bakedSha={bakedSha} title={parsed?.title} meta={parsed?.meta} titleOwned={!!profileTitle} client:load />
      {contributor && <Contributions login={contributor} client:load />}
    </div>
    <div class="col-info">
      <Appearance client:idle />
    </div>
  </main>
</PageShell>
