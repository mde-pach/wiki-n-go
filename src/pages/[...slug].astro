---
import Infobox from "../components/Infobox.tsx";
import Toc from "../components/Toc.tsx";
import WikiPage from "../components/WikiPage.tsx";
import { config } from "../config";
import PageShell from "../layouts/PageShell.astro";

export function getStaticPaths() {
  const files = import.meta.glob("../../content/**/*.md");
  const slugs = Object.keys(files).map((p) =>
    p.replace("../../content/", "").replace(/\.md$/, ""),
  );
  return [
    { params: { slug: undefined } },
    ...slugs.filter((s) => s !== config.homeSlug).map((s) => ({ params: { slug: s } })),
  ];
}

const { slug } = Astro.params;
const pageSlug = slug ?? config.homeSlug;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<PageShell slug={pageSlug} view="read">
  <main id="main" class="read-grid">
    <div class="col-toc"><Toc editHref={`${base}/edit/${pageSlug}`} client:load /></div>
    <div class="col-main"><WikiPage slug={pageSlug} client:load /></div>
    <div class="col-info"><Infobox slug={pageSlug} client:load /></div>
  </main>
</PageShell>
