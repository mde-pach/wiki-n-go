---
import History from "../../components/History.tsx";
import PageShell from "../../layouts/PageShell.astro";
import { parsePage } from "../../lib/markdown";
import { rawPage, staticPaths } from "../../lib/pages";

export function getStaticPaths() {
  return staticPaths();
}

const { slug } = Astro.params;
const raw = rawPage(slug);
const parsed = raw ? parsePage(raw) : null;
---

<PageShell slug={slug} view="history" title={parsed?.title} categories={parsed?.meta?.tags}>
  <main id="main" class="view-wrap"><History slug={slug} client:load /></main>
</PageShell>
