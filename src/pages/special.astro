---
import "../styles/app.css";
import Appearance from "../components/Appearance.tsx";
import Search from "../components/Search.tsx";
import Special from "../components/Special.tsx";
import { BASE } from "../lib/paths";

const home = `${BASE}/`;
---

<!doctype html>
<html lang="en" data-skin="wiki-n-go" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Special pages · wiki-n-go</title>
    <script is:inline>
      (() => {
        const skins = ["wiki-n-go", "wiki"];
        const d = document.documentElement;
        const saved = localStorage.getItem("wng-skin");
        d.dataset.skin = skins.includes(saved) ? saved : "wiki-n-go";
        d.dataset.theme = localStorage.getItem("wng-theme") || "light";
        d.dataset.width = localStorage.getItem("wng-width") || "standard";
        const ready = () => d.classList.add("ready");
        if (document.readyState === "complete") ready();
        else addEventListener("load", ready, { once: true });
      })();
    </script>
  </head>
  <body>
    <div class="app">
      <a class="skip-link" href="#main">Skip to content</a>
      <header class="header">
        <div class="header-inner">
          <a class="wordmark" href={home}>
            <span>wiki</span><span class="wm-accent">-n-</span><span>go</span><span class="wm-dot"></span>
            <span class="wordmark-sub">the open reference</span>
          </a>
          <Search client:load />
          <div class="header-actions">
            <Appearance client:load />
            <button class="btn btn-outline btn-sm signin" disabled>Sign in</button>
          </div>
        </div>
      </header>

      <main id="main" class="view-wrap">
        <Special client:load />
      </main>
    </div>
  </body>
</html>
