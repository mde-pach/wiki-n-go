---
import Editor from "../../components/Editor.tsx";
import PageShell from "../../layouts/PageShell.astro";
import { parsePage } from "../../lib/markdown";

const rawPages = import.meta.glob("../../../content/**/*.md", {
  query: "?raw",
  import: "default",
  eager: true,
}) as Record<string, string>;

export function getStaticPaths() {
  const files = import.meta.glob("../../../content/**/*.md");
  return Object.keys(files).map((p) => ({
    params: { slug: p.replace("../../../content/", "").replace(/\.md$/, "") },
  }));
}

const { slug } = Astro.params;
const raw = rawPages[`../../../content/${slug}.md`];
const title = raw ? parsePage(raw).title : undefined;
---

<PageShell slug={slug} view="edit" title={title}>
  <main id="main" class="view-wrap">
    <Editor slug={slug} initialContent={raw} client:load />
  </main>
</PageShell>
