---
import Editor from "../../components/Editor.tsx";
import PageShell from "../../layouts/PageShell.astro";
import { parsePage } from "../../lib/markdown";
import { rawPage, staticPaths } from "../../lib/pages";
import { BASE, contentSlugForRoute } from "../../lib/paths";

export function getStaticPaths() {
  return staticPaths();
}

const slug = contentSlugForRoute(Astro.params.slug);
const raw = rawPage(slug);
const parsed = raw ? parsePage(raw) : null;
---

<PageShell slug={slug} view="edit" title={parsed?.title} categories={parsed?.meta?.tags}>
  <main id="main" class="view-wrap edit-view">
    <p class="edit-help-hint">
      New to editing? See the <a href={`${BASE}/formatting`}>formatting guide</a>
      · <a href={`${BASE}/editing`}>how contributing works</a>.
    </p>
    <Editor slug={slug} initialContent={raw} client:load />
  </main>
</PageShell>
