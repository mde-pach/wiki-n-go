---
import Editor from "../../components/Editor.tsx";
import PageShell from "../../layouts/PageShell.astro";
import { parsePage } from "../../lib/markdown";
import { rawPage, staticPaths } from "../../lib/pages";

export function getStaticPaths() {
  return staticPaths();
}

const { slug } = Astro.params;
const raw = rawPage(slug);
const title = raw ? parsePage(raw).title : undefined;
---

<PageShell slug={slug} view="edit" title={title}>
  <main id="main" class="view-wrap">
    <Editor slug={slug} initialContent={raw} client:load />
  </main>
</PageShell>
