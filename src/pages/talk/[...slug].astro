---
import Discussion from "../../components/Discussion.tsx";
import PageShell from "../../layouts/PageShell.astro";
import { parsePage } from "../../lib/markdown";
import { rawPage, staticPaths } from "../../lib/pages";
import { contentSlugForRoute } from "../../lib/paths";

export function getStaticPaths() {
  return staticPaths();
}

const slug = contentSlugForRoute(Astro.params.slug);
const raw = rawPage(slug);
const parsed = raw ? parsePage(raw) : null;
---

<PageShell slug={slug} view="talk" title={parsed?.title} categories={parsed?.meta?.tags}>
  <main id="main" class="view-wrap"><Discussion slug={slug} client:load /></main>
</PageShell>
