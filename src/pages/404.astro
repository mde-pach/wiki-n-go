---
import "../styles/app.css";
import Route404 from "../components/Route404.tsx";

const home = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en" data-skin="editorial" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>wiki-n-go</title>
    <script is:inline>
      (() => {
        const apply = (doc) => {
          const d = doc.documentElement;
          d.dataset.skin = localStorage.getItem("wng-skin") || "editorial";
          d.dataset.theme = localStorage.getItem("wng-theme") || "light";
        };
        apply(document);
        document.addEventListener("astro:before-swap", (e) => apply(e.newDocument));
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,400..700;1,8..60,400..600&family=Libre+Franklin:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="app">
      <header class="header">
        <div class="header-inner">
          <a class="wordmark" href={home}>
            <span>wiki</span><span class="wm-accent">-n-</span><span>go</span><span class="wm-dot"></span>
          </a>
        </div>
      </header>
      <Route404 client:only="solid-js" />
    </div>
  </body>
</html>
