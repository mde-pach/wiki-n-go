---
import "../styles/app.css";
import AuthButton from "../components/AuthButton.tsx";
import MainMenu from "../components/MainMenu.tsx";
import Route404 from "../components/Route404.tsx";
import Search from "../components/Search.tsx";
import ThemeBoot from "../components/ThemeBoot.astro";
import TokenCapture from "../components/TokenCapture.astro";

const home = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en" data-skin="wiki-n-go" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>wiki-n-go</title>
    <ThemeBoot />
    <TokenCapture />
  </head>
  <body>
    <div class="app">
      <a class="skip-link" href="#main">Skip to content</a>
      <header class="header">
        <div class="header-inner">
          <MainMenu client:load />
          <a class="wordmark" href={home}>
            <span>wiki</span><span class="wm-accent">-n-</span><span>go</span><span class="wm-dot"></span>
            <span class="wordmark-sub">the open reference</span>
          </a>
          <Search client:load />
          <div class="header-actions">
            <AuthButton client:load />
          </div>
        </div>
      </header>
      <Route404 client:only="solid-js" />
    </div>
  </body>
</html>
