---
import "../styles/app.css";
import Route404 from "../components/Route404.tsx";
import SiteHeader from "../components/SiteHeader.astro";
import ThemeBoot from "../components/ThemeBoot.astro";
import TokenCapture from "../components/TokenCapture.astro";

const home = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en" data-skin="wikigit" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Wikigit</title>
    <ThemeBoot />
    <TokenCapture />
  </head>
  <body>
    <div class="app">
      <a class="skip-link" href="#main">Skip to content</a>
      <SiteHeader home={home} />
      <Route404 client:only="solid-js" />
    </div>
  </body>
</html>
