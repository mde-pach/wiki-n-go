---
import "../styles/app.css";
import Route404 from "../components/Route404.tsx";

const home = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en" data-skin="editorial" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>wiki-n-go</title>
    <script is:inline>
      (() => {
        const apply = (doc) => {
          const d = doc.documentElement;
          d.dataset.skin = localStorage.getItem("wng-skin") || "editorial";
          d.dataset.theme = localStorage.getItem("wng-theme") || "light";
        };
        apply(document);
        const ready = () => document.documentElement.classList.add("ready");
        if (document.readyState === "complete") ready();
        else addEventListener("load", ready, { once: true });
        document.addEventListener("astro:before-swap", (e) => apply(e.newDocument));
      })();
    </script>
  </head>
  <body>
    <div class="app">
      <header class="header">
        <div class="header-inner">
          <a class="wordmark" href={home}>
            <span>wiki</span><span class="wm-accent">-n-</span><span>go</span><span class="wm-dot"></span>
          </a>
        </div>
      </header>
      <Route404 client:only="solid-js" />
    </div>
  </body>
</html>
