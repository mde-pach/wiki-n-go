---
import "../styles/app.css";
import Route404 from "../components/Route404.tsx";

const home = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en" data-skin="wiki-n-go" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>wiki-n-go</title>
    <script is:inline>
      (() => {
        const skins = ["wiki-n-go", "wiki"];
        const apply = (doc) => {
          const d = doc.documentElement;
          const saved = localStorage.getItem("wng-skin");
          d.dataset.skin = skins.includes(saved) ? saved : "wiki-n-go";
          const pref = localStorage.getItem("wng-theme") || "light";
          d.dataset.theme =
            pref === "dark" ||
            (pref === "auto" && matchMedia("(prefers-color-scheme: dark)").matches)
              ? "dark"
              : "light";
          d.dataset.width = localStorage.getItem("wng-width") || "standard";
          d.dataset.textsize = localStorage.getItem("wng-textsize") || "standard";
        };
        apply(document);
        const ready = () => document.documentElement.classList.add("ready");
        if (document.readyState === "complete") ready();
        else addEventListener("load", ready, { once: true });
        document.addEventListener("astro:before-swap", (e) => apply(e.newDocument));
      })();
    </script>
  </head>
  <body>
    <div class="app">
      <header class="header">
        <div class="header-inner">
          <a class="wordmark" href={home}>
            <span>wiki</span><span class="wm-accent">-n-</span><span>go</span><span class="wm-dot"></span>
          </a>
        </div>
      </header>
      <Route404 client:only="solid-js" />
    </div>
  </body>
</html>
