---
// The global top bar shared by the standalone pages (new, move, cite, special,
// admin) and the 404 fallback. PageShell renders its own variant (it adds
// transition:persist and points the wordmark at the page's read URL).
import AuthButton from "./AuthButton.tsx";
import MainMenu from "./MainMenu.tsx";
import Search from "./Search.tsx";

interface Props {
  home: string;
}
const { home } = Astro.props;
---

<header class="header">
  <div class="header-inner">
    <MainMenu client:load />
    <a class="wordmark" href={home}>
      <span>wiki</span><span class="wm-accent">git</span><span class="wm-dot"></span>
      <span class="wordmark-sub">the open reference</span>
    </a>
    <Search client:load />
    <div class="header-actions">
      <AuthButton client:load />
    </div>
  </div>
</header>
