---
import "../styles/app.css";
import { ClientRouter } from "astro:transitions";
import AuthButton from "../components/AuthButton.tsx";
import MainMenu from "../components/MainMenu.tsx";
import PageMeta from "../components/PageMeta.tsx";
import Search from "../components/Search.tsx";
import ThemeBoot from "../components/ThemeBoot.astro";
import TokenCapture from "../components/TokenCapture.astro";
import { config } from "../config";
import { gitRevisions } from "../lib/git";
import { translations } from "../lib/i18n";
import {
  adminHref,
  BASE,
  categoryHref,
  changesHref,
  langOf,
  prettify,
  readHref,
  reviewHref,
  type View,
} from "../lib/paths";

interface Props {
  slug: string;
  view: View;
  title?: string;
  categories?: string[];
  description?: string;
}
const { slug, view, title, categories, description } = Astro.props;

const revisions = gitRevisions(slug);
const read = readHref(slug);
const href = {
  read,
  edit: `${BASE}/edit/${slug}`,
  history: `${BASE}/history/${slug}`,
  talk: `${BASE}/talk/${slug}`,
};
const tabs = [
  ["read", "Read"],
  ["edit", "Edit"],
  ["history", "History"],
  ["talk", "Talk"],
] as const;

const display = title ?? prettify(slug);
const source = `${config.contentDir}/${slug}.md`;
const sourceUrl = `https://github.com/${config.repoOwner}/${config.repoName}/blob/${config.branch}/${source}`;

const pageLang = langOf(slug);
const langs = translations(slug);
const alternates = langs.filter((l) => !l.current);
---

<!doctype html>
<html lang={pageLang} data-skin="wiki-n-go" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    {description && <meta name="description" content={description} />}
    {
      alternates.map((l) => (
        <link rel="alternate" hreflang={l.lang} href={new URL(readHref(l.slug), Astro.site)} />
      ))
    }
    <title>{display} · wiki-n-go</title>
    <ThemeBoot />
    <ClientRouter />
    <TokenCapture />
  </head>
  <body>
    <div class="app">
      <a class="skip-link" href="#main">Skip to content</a>
      <header class="header" transition:persist>
        <div class="header-inner">
          <MainMenu client:load />
          <a class="wordmark" href={read}>
            <span>wiki</span><span class="wm-accent">-n-</span><span>go</span><span class="wm-dot"></span>
            <span class="wordmark-sub">the open reference</span>
          </a>
          <Search client:load />
          <div class="header-actions">
            <AuthButton client:load />
          </div>
        </div>
      </header>

      <div class="page-head">
        <div class="page-head-inner">
          <div class="page-head-top">
            <h1 class="page-title">{display}</h1>
            {
              langs.length > 1 && (
                <details class="langbar">
                  <summary class="langbar-toggle">
                    <svg viewBox="0 0 20 20" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.6">
                      <circle cx="10" cy="10" r="7.5" />
                      <path d="M2.5 10h15M10 2.5c2.5 2.4 2.5 12.6 0 15M10 2.5c-2.5 2.4-2.5 12.6 0 15" />
                    </svg>
                    <span>{langs.length} languages</span>
                  </summary>
                  <ul class="langbar-menu">
                    {langs.map((l) => (
                      <li>
                        <a
                          href={readHref(l.slug)}
                          lang={l.lang}
                          aria-current={l.current ? "page" : undefined}
                        >
                          {l.name}
                        </a>
                      </li>
                    ))}
                  </ul>
                </details>
              )
            }
          </div>
          <div class="page-meta-slot">
            <PageMeta slug={slug} base={BASE} initial={revisions} client:load />
          </div>
          <nav class="tabbar" aria-label="Page views">
            {
              tabs.map(([id, label]) => (
                <a
                  class={`tab${view === id ? " is-active" : ""}`}
                  href={href[id]}
                  aria-current={view === id ? "page" : undefined}
                >
                  <span class="tab-label">{label}</span>
                </a>
              ))
            }
          </nav>
        </div>
      </div>

      <slot />

      <footer class="site-footer">
        <div class="footer-inner">
          {
            categories && categories.length > 0 && (
              <div class="cat-row">
                <span class="cat-label">Categories</span>
                {categories.map((c) => (
                  <a class="chip chip-link" href={categoryHref(c)}>
                    {c}
                  </a>
                ))}
              </div>
            )
          }
          <div class="footer-tools">
            <a href={changesHref}>Recent changes</a>
            <span class="sep">·</span>
            <a href={reviewHref}>Pending review</a>
            <span class="sep">·</span>
            <a href={adminHref}>Admin</a>
          </div>
          <div class="footer-bottom">
            <p class="fb-license">
              Text is available under the CC BY-SA 4.0 license; the wiki-n-go software is
              MIT-licensed. Content is stored as Markdown and is editable by anyone.
            </p>
            <a class="provenance" href={sourceUrl} target="_blank" rel="noreferrer">
              <span>View page source · <span class="mono">{source}</span></span>
            </a>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
