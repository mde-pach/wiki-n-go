---
import "../styles/app.css";
import { ClientRouter } from "astro:transitions";
import PageMeta from "../components/PageMeta.tsx";
import Search from "../components/Search.tsx";
import ThemeToggle from "../components/ThemeToggle.tsx";
import { config } from "../config";

interface Props {
  slug: string;
  view: "read" | "edit" | "history" | "talk";
}
const { slug, view } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const readHref = slug === config.homeSlug ? `${base}/` : `${base}/${slug}`;
const href = {
  read: readHref,
  edit: `${base}/edit/${slug}`,
  history: `${base}/history/${slug}`,
  talk: `${base}/talk/${slug}`,
};
const tabs = [
  ["read", "Read"],
  ["edit", "Edit"],
  ["history", "History"],
  ["talk", "Talk"],
] as const;

const pretty = (slug.split("/").pop() ?? slug)
  .replace(/-/g, " ")
  .replace(/^\w/, (c) => c.toUpperCase());
const source = `${config.contentDir}/${slug}.md`;
const sourceUrl = `https://github.com/${config.repoOwner}/${config.repoName}/blob/${config.branch}/${source}`;
---

<!doctype html>
<html lang="en" data-skin="editorial" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pretty} · wiki-n-go</title>
    <script is:inline>
      (() => {
        const apply = (doc) => {
          const d = doc.documentElement;
          d.dataset.skin = localStorage.getItem("wng-skin") || "editorial";
          d.dataset.theme = localStorage.getItem("wng-theme") || "light";
        };
        apply(document);
        // Re-apply on View Transition navigation (the swapped-in doc carries the SSR defaults).
        document.addEventListener("astro:before-swap", (e) => apply(e.newDocument));
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,400..700;1,8..60,400..600&family=Libre+Franklin:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
  </head>
  <body>
    <div class="app">
      <a class="skip-link" href="#main">Skip to content</a>
      <header class="header" transition:persist>
        <div class="header-inner">
          <a class="wordmark" href={readHref}>
            <span>wiki</span><span class="wm-accent">-n-</span><span>go</span><span class="wm-dot"></span>
            <span class="wordmark-sub">the open reference</span>
          </a>
          <Search client:only="solid-js" />
          <div class="header-actions">
            <ThemeToggle client:only="solid-js" />
            <button class="btn btn-outline btn-sm signin" disabled>Sign in</button>
          </div>
        </div>
      </header>

      <div class="page-head">
        <div class="page-head-inner">
          <nav class="breadcrumb" aria-label="Breadcrumb">
            <a href={readHref}>Main</a><span class="sep">/</span><span>Article</span>
          </nav>
          <h1 class="page-title">{pretty}</h1>
          <div class="page-meta-slot">
            <PageMeta slug={slug} base={base} client:only="solid-js" />
          </div>
          <nav class="tabbar" aria-label="Page views">
            {
              tabs.map(([id, label]) => (
                <a
                  class={`tab${view === id ? " is-active" : ""}`}
                  href={href[id]}
                  aria-current={view === id ? "page" : undefined}
                >
                  <span class="tab-label">{label}</span>
                </a>
              ))
            }
          </nav>
        </div>
      </div>

      <slot />

      <footer class="site-footer">
        <div class="footer-inner">
          <div class="cat-row">
            <span class="cat-label">Categories</span>
            <span class="chip">Wiki</span>
          </div>
          <div class="footer-bottom">
            <p class="fb-license">
              Text is available under the CC BY-SA 4.0 license; the wiki-n-go software is
              MIT-licensed. Content is stored as Markdown and is editable by anyone.
            </p>
            <a class="provenance" href={sourceUrl} target="_blank" rel="noreferrer">
              <span>View this page on GitHub · <span class="mono">{source}</span></span>
            </a>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
