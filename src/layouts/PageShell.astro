---
import "../styles/app.css";
import { ClientRouter } from "astro:transitions";
import AuthButton from "../components/AuthButton.tsx";
import LangBar from "../components/LangBar.tsx";
import MainMenu from "../components/MainMenu.tsx";
import PageMeta from "../components/PageMeta.tsx";
import PatrolMeta from "../components/PatrolMeta.tsx";
import Search from "../components/Search.tsx";
import ThemeBoot from "../components/ThemeBoot.astro";
import TokenCapture from "../components/TokenCapture.astro";
import { config } from "../config";
import { gitRevisions } from "../lib/git";
import { translationGroup, translations } from "../lib/i18n";
import {
  adminHref,
  BASE,
  categoryHref,
  changesHref,
  langOf,
  prettify,
  readHref,
  reviewHref,
  type View,
} from "../lib/paths";

interface Props {
  slug: string;
  view: View;
  title?: string;
  categories?: string[];
  description?: string;
}
const { slug, view, title, categories, description } = Astro.props;

const revisions = gitRevisions(slug);
const read = readHref(slug);
const href = {
  read,
  edit: `${BASE}/edit/${slug}`,
  history: `${BASE}/history/${slug}`,
  talk: `${BASE}/talk/${slug}`,
};
const viewTabs = [
  ["read", "Read"],
  ["edit", "Edit"],
  ["history", "History"],
] as const;
const namespace = view === "talk" ? "talk" : "article";

const display = title ?? prettify(slug);
const source = `${config.contentDir}/${slug}.md`;
const sourceUrl = `https://github.com/${config.repoOwner}/${config.repoName}/blob/${config.branch}/${source}`;

const pageRef = encodeURIComponent(slug);
const toolLinks: { label: string; href: string; external?: boolean }[] = [
  { label: "What links here", href: `${BASE}/special?tab=backlinks&page=${pageRef}` },
  { label: "Page information", href: `${BASE}/special?tab=pageinfo&page=${pageRef}` },
  { label: "Cite this page", href: `${BASE}/cite` },
  { label: "Move or rename", href: `${BASE}/move?page=${pageRef}` },
  { label: "View page source", href: sourceUrl, external: true },
];

const pageLang = langOf(slug);
const group = translationGroup(slug);
const alternates = translations(slug).filter((l) => !l.current);
---

<!doctype html>
<html lang={pageLang} data-skin="wikigit" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    {description && <meta name="description" content={description} />}
    {
      alternates.map((l) => (
        <link rel="alternate" hreflang={l.lang} href={new URL(readHref(l.slug), Astro.site)} />
      ))
    }
    <title>{display} · Wikigit</title>
    <ThemeBoot />
    <ClientRouter />
    <TokenCapture />
  </head>
  <body>
    <div class="app">
      <a class="skip-link" href="#main">Skip to content</a>
      <header class="header" transition:persist>
        <div class="header-inner">
          <MainMenu client:load />
          <a class="wordmark" href={read}>
            <span>wiki</span><span class="wm-accent">git</span><span class="wm-dot"></span>
            <span class="wordmark-sub">the open reference</span>
          </a>
          <Search client:load />
          <div class="header-actions">
            <AuthButton client:load />
          </div>
        </div>
      </header>

      <div class="page-head">
        <div class="page-head-inner">
          <div class="page-head-top">
            <h1 class="page-title">{display}</h1>
            {
              group && (
                <LangBar
                  slug={slug}
                  translationKey={group.key}
                  initialSiblings={group.slugs}
                  client:load
                />
              )
            }
          </div>
          <div class="page-meta-slot">
            <PageMeta slug={slug} base={BASE} initial={revisions} client:load />
          </div>
          {view === "read" && <PatrolMeta slug={slug} client:idle />}
          <nav class="tabbar" aria-label="Page navigation">
            <div class="tab-group tab-ns">
              <a class={`tab${namespace === "article" ? " is-active" : ""}`} href={read}>
                <span class="tab-label">Article</span>
              </a>
              <a
                class={`tab${namespace === "talk" ? " is-active" : ""}`}
                href={href.talk}
                aria-current={view === "talk" ? "page" : undefined}
              >
                <span class="tab-label">Discussion</span>
              </a>
            </div>
            <div class="tab-group tab-views">
              {
                viewTabs.map(([id, label]) => (
                  <a
                    class={`tab${view === id ? " is-active" : ""}`}
                    href={href[id]}
                    aria-current={view === id ? "page" : undefined}
                  >
                    <span class="tab-label">{label}</span>
                  </a>
                ))
              }
              <details class="page-tools tab-tools">
                <summary class="tab">
                  <span class="tab-label">Tools</span>
                  <svg
                    class="chev"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.7"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="M6 9l6 6 6-6"></path>
                  </svg>
                </summary>
                <div class="menu" role="menu">
                  <span class="menu-label">Page tools</span>
                  {
                    toolLinks.map((t) => (
                      <a
                        class="menu-item"
                        role="menuitem"
                        href={t.href}
                        {...(t.external ? { target: "_blank", rel: "noreferrer" } : {})}
                      >
                        {t.label}
                      </a>
                    ))
                  }
                </div>
              </details>
            </div>
          </nav>
        </div>
      </div>

      <slot />

      <footer class="site-footer">
        <div class="footer-inner">
          {
            categories && categories.length > 0 && (
              <div class="cat-row">
                <span class="cat-label">Categories</span>
                {categories.map((c) => (
                  <a class="chip chip-link" href={categoryHref(c)}>
                    {c}
                  </a>
                ))}
              </div>
            )
          }
          <div class="footer-tools">
            <a href={changesHref}>Recent changes</a>
            <span class="sep">·</span>
            <a href={reviewHref}>Pending review</a>
            <span class="sep">·</span>
            <a href={adminHref}>Admin</a>
          </div>
          <div class="footer-bottom">
            <p class="fb-license">
              Text is available under the CC BY-SA 4.0 license; the Wikigit software is
              MIT-licensed. Content is stored as Markdown and is editable by anyone.
            </p>
            <a class="provenance" href={sourceUrl} target="_blank" rel="noreferrer">
              <span>View page source · <span class="mono">{source}</span></span>
            </a>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
