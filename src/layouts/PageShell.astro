---
import "../styles/app.css";
import { ClientRouter } from "astro:transitions";
import Appearance from "../components/Appearance.tsx";
import PageMeta from "../components/PageMeta.tsx";
import Search from "../components/Search.tsx";
import { config } from "../config";
import { gitRevisions } from "../lib/git";
import {
  BASE,
  categoryHref,
  changesHref,
  prettify,
  readHref,
  type View,
} from "../lib/paths";

interface Props {
  slug: string;
  view: View;
  title?: string;
  categories?: string[];
}
const { slug, view, title, categories } = Astro.props;

const revisions = gitRevisions(slug);
const read = readHref(slug);
const href = {
  read,
  edit: `${BASE}/edit/${slug}`,
  history: `${BASE}/history/${slug}`,
  talk: `${BASE}/talk/${slug}`,
};
const tabs = [
  ["read", "Read"],
  ["edit", "Edit"],
  ["history", "History"],
  ["talk", "Talk"],
] as const;

const display = title ?? prettify(slug);
const source = `${config.contentDir}/${slug}.md`;
const sourceUrl = `https://github.com/${config.repoOwner}/${config.repoName}/blob/${config.branch}/${source}`;
---

<!doctype html>
<html lang="en" data-skin="wiki-n-go" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{display} · wiki-n-go</title>
    <script is:inline>
      (() => {
        const skins = ["wiki-n-go", "wiki"];
        const apply = (doc) => {
          const d = doc.documentElement;
          const saved = localStorage.getItem("wng-skin");
          d.dataset.skin = skins.includes(saved) ? saved : "wiki-n-go";
          d.dataset.theme = localStorage.getItem("wng-theme") || "light";
          d.dataset.width = localStorage.getItem("wng-width") || "standard";
        };
        apply(document);
        const ready = () => document.documentElement.classList.add("ready");
        if (document.readyState === "complete") ready();
        else addEventListener("load", ready, { once: true });
        // Re-apply on View Transition navigation (the swapped-in doc carries the SSR defaults).
        document.addEventListener("astro:before-swap", (e) => apply(e.newDocument));
      })();
    </script>
    <ClientRouter />
  </head>
  <body>
    <div class="app">
      <a class="skip-link" href="#main">Skip to content</a>
      <header class="header" transition:persist>
        <div class="header-inner">
          <a class="wordmark" href={read}>
            <span>wiki</span><span class="wm-accent">-n-</span><span>go</span><span class="wm-dot"></span>
            <span class="wordmark-sub">the open reference</span>
          </a>
          <Search client:load />
          <div class="header-actions">
            <Appearance client:load />
            <button class="btn btn-outline btn-sm signin" disabled>Sign in</button>
          </div>
        </div>
      </header>

      <div class="page-head">
        <div class="page-head-inner">
          <h1 class="page-title">{display}</h1>
          <div class="page-meta-slot">
            <PageMeta slug={slug} base={BASE} initial={revisions} client:load />
          </div>
          <nav class="tabbar" aria-label="Page views">
            {
              tabs.map(([id, label]) => (
                <a
                  class={`tab${view === id ? " is-active" : ""}`}
                  href={href[id]}
                  aria-current={view === id ? "page" : undefined}
                >
                  <span class="tab-label">{label}</span>
                </a>
              ))
            }
          </nav>
        </div>
      </div>

      <slot />

      <footer class="site-footer">
        <div class="footer-inner">
          {
            categories && categories.length > 0 && (
              <div class="cat-row">
                <span class="cat-label">Categories</span>
                {categories.map((c) => (
                  <a class="chip chip-link" href={categoryHref(c)}>
                    {c}
                  </a>
                ))}
              </div>
            )
          }
          <div class="footer-tools">
            <a href={changesHref}>Recent changes</a>
          </div>
          <div class="footer-bottom">
            <p class="fb-license">
              Text is available under the CC BY-SA 4.0 license; the wiki-n-go software is
              MIT-licensed. Content is stored as Markdown and is editable by anyone.
            </p>
            <a class="provenance" href={sourceUrl} target="_blank" rel="noreferrer">
              <span>View this page on GitHub · <span class="mono">{source}</span></span>
            </a>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
