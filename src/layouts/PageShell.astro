---
import "../styles/app.css";
import { ClientRouter } from "astro:transitions";
import AuthBoot from "../components/AuthBoot.astro";
import AuthButton from "../components/AuthButton.tsx";
import LangBar from "../components/LangBar.tsx";
import MainMenu from "../components/MainMenu.tsx";
import PageMeta from "../components/PageMeta.tsx";
import PatrolMeta from "../components/PatrolMeta.tsx";
import Search from "../components/Search.tsx";
import SiteBoot from "../components/SiteBoot.tsx";
import ThemeBoot from "../components/ThemeBoot.astro";
import TokenCapture from "../components/TokenCapture.astro";
import { type AppearanceDefaults, config } from "../config";
import { classifyTags } from "../lib/categories";
import { translationGroup, translations, wikiLanguages } from "../lib/i18n";
import {
  adminHref,
  BASE,
  categoryHref,
  changesHref,
  createHref,
  langOf,
  prettify,
  readHref,
  reviewHref,
  settingsHref,
  setupHref,
  type View,
  viewHref,
} from "../lib/paths";
import { fetchRevisions } from "../lib/ssr";

interface Props {
  slug: string;
  view: View;
  title?: string;
  categories?: string[];
  description?: string;
  appearance?: Partial<AppearanceDefaults>;
  // Edge-SSR (off by default): the content route resolves patrol state
  // server-side and passes `ssr` so this layout emits a real robots=noindex in
  // the head (instead of the client PatrolMeta island) and OG/canonical tags.
  ssr?: boolean;
  noindex?: boolean;
}
const { slug, view, title, categories, description, appearance, ssr, noindex } =
  Astro.props;

// `gitRevisions` reads local git (build only, uses node:child_process); load it
// lazily so it stays out of the edge bundle. The edge path fetches the same data
// from the Worker so the "last edited" line is server-rendered there too.
const revisions = ssr
  ? await fetchRevisions(slug)
  : await import("../lib/git").then((m) => m.gitRevisions(slug));
const read = readHref(slug);
const href = {
  read,
  edit: viewHref("edit", slug),
  history: viewHref("history", slug),
  talk: viewHref("talk", slug),
};
const viewTabs = [
  ["read", "Read"],
  ["edit", "Edit"],
  ["history", "History"],
] as const;
const namespace = view === "talk" ? "talk" : "article";

const display = title ?? prettify(slug);
const source = `${config.contentDir}/${slug}.md`;
const sourceUrl = `https://github.com/${config.repoOwner}/${config.repoName}/blob/${config.branch}/${source}`;

const pageRef = encodeURIComponent(slug);
const toolLinks: { label: string; href: string; external?: boolean }[] = [
  { label: "What links here", href: `${BASE}/special?tab=backlinks&page=${pageRef}` },
  { label: "Page information", href: `${BASE}/special?tab=pageinfo&page=${pageRef}` },
  { label: "Cite this page", href: `${BASE}/cite` },
  { label: "Move or rename", href: `${BASE}/move?page=${pageRef}` },
  { label: "View page source", href: sourceUrl, external: true },
];

const pageLang = langOf(slug);
const group = translationGroup(slug);
const alternates = translations(slug).filter((l) => !l.current);
const cats = categories?.length ? classifyTags(categories) : null;

const canonical = new URL(read, Astro.site).href;
---

<!doctype html>
<html lang={pageLang} data-skin="wikigit" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={`${BASE}/favicon.svg`} />
    {description && <meta name="description" content={description} />}
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="article" />
    <meta property="og:site_name" content="Wikigit" />
    <meta property="og:title" content={display} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />
    {
      alternates.map((l) => (
        <link rel="alternate" hreflang={l.lang} href={new URL(readHref(l.slug), Astro.site)} />
      ))
    }
    <title>{display} · Wikigit</title>
    <ThemeBoot appearance={appearance} />
    <ClientRouter />
    {/* Keep in-site navigation (no full reload) but swap pages instantly — a
        regular wiki feel, not a cross-fade. */}
    <style is:global>
      ::view-transition-old(root),
      ::view-transition-new(root) {
        animation: none;
      }
    </style>
    <TokenCapture />
  </head>
  <body>
    <div class="app">
      <a class="skip-link" href="#main">Skip to content</a>
      <SiteBoot client:idle />
      <header class="header" transition:persist>
        <div class="header-inner">
          <MainMenu client:load />
          <a class="wordmark" href={read}>
            <span>wiki</span><span class="wm-accent">git</span><span class="wm-dot"></span>
            <span class="wordmark-sub">the open reference</span>
          </a>
          <script is:inline>
            /* Pre-paint: rewrite the wordmark to a hosted tenant's title/tagline
               (cached by SiteBoot) so a reload doesn't flash the generic brand.
               First-ever load has no cache → SiteBoot patches once, async. */
            (() => {
              try {
                const raw = sessionStorage.getItem("wikigit:chrome:" + location.host);
                const c = raw && JSON.parse(raw);
                if (!c || !c.title) return;
                for (const el of document.querySelectorAll(".wordmark")) {
                  el.textContent = "";
                  const t = document.createElement("span");
                  t.className = "wm-title";
                  t.textContent = c.title;
                  el.appendChild(t);
                  if (c.tagline) {
                    const s = document.createElement("span");
                    s.className = "wordmark-sub";
                    s.textContent = c.tagline;
                    el.appendChild(s);
                  }
                }
              } catch {}
            })();
          </script>
          <Search client:load />
          <div class="header-actions">
            <AuthBoot />
            <AuthButton client:only="solid-js" />
          </div>
        </div>
      </header>

      <div class="page-head">
        <div class="page-head-inner">
          <div class="page-head-top">
            <h1 class="page-title">{display}</h1>
            {
              group && (
                <LangBar
                  slug={slug}
                  translationKey={group.key}
                  initialSiblings={group.slugs}
                  wikiLangs={wikiLanguages()}
                  client:load
                />
              )
            }
          </div>
          <div class="page-meta-slot">
            <PageMeta slug={slug} initial={revisions} client:load />
          </div>
          {view === "read" && !ssr && <PatrolMeta slug={slug} client:idle />}
          <nav class="tabbar" aria-label="Page navigation">
            <div class="tab-group tab-ns">
              <a class={`tab${namespace === "article" ? " is-active" : ""}`} href={read}>
                <span class="tab-label">Article</span>
              </a>
              <a
                class={`tab${namespace === "talk" ? " is-active" : ""}`}
                href={href.talk}
                aria-current={view === "talk" ? "page" : undefined}
              >
                <span class="tab-label">Discussion</span>
              </a>
            </div>
            <div class="tab-group tab-views">
              {
                viewTabs.map(([id, label]) => (
                  <a
                    class={`tab${view === id ? " is-active" : ""}`}
                    href={href[id]}
                    aria-current={view === id ? "page" : undefined}
                  >
                    <span class="tab-label">{label}</span>
                  </a>
                ))
              }
              <details class="page-tools tab-tools">
                <summary class="tab">
                  <span class="tab-label">Tools</span>
                  <svg
                    class="chev"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.7"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="M6 9l6 6 6-6"></path>
                  </svg>
                </summary>
                <div class="menu" role="menu">
                  <span class="menu-label">Page tools</span>
                  {
                    toolLinks.map((t) => (
                      <a
                        class="menu-item"
                        role="menuitem"
                        href={t.href}
                        {...(t.external ? { target: "_blank", rel: "noreferrer" } : {})}
                      >
                        {t.label}
                      </a>
                    ))
                  }
                </div>
              </details>
            </div>
          </nav>
        </div>
      </div>

      <slot />

      <footer class="site-footer">
        <div class="footer-inner">
          {
            cats && (cats.topical.length > 0 || cats.maintenance.length > 0) && (
              <div class="cat-block">
                {cats.topical.length > 0 && (
                  <div class="cat-row">
                    <span class="cat-label">Categories</span>
                    {cats.topical.map((c) => (
                      <a class="chip chip-link" href={categoryHref(c)}>
                        {c}
                      </a>
                    ))}
                  </div>
                )}
                {cats.maintenance.length > 0 && (
                  <div class="cat-row cat-row-maint">
                    <span class="cat-label">Maintenance</span>
                    {cats.maintenance.map((c) => (
                      <a class="chip chip-link" href={categoryHref(c)}>
                        {c}
                      </a>
                    ))}
                  </div>
                )}
              </div>
            )
          }
          <div class="footer-tools">
            <a href={changesHref}>Recent changes</a>
            <span class="sep">·</span>
            <a href={reviewHref}>Pending review</a>
            <span class="sep">·</span>
            <a href={adminHref}>Admin</a>
            <span class="sep">·</span>
            <a href={setupHref}>Setup</a>
            <span class="sep">·</span>
            <a href={settingsHref}>Settings</a>
            <span class="sep">·</span>
            <a href={createHref}>Create a wiki</a>
          </div>
          <div class="footer-bottom">
            <p class="fb-license">
              Text is available under the CC BY-SA 4.0 license; the Wikigit software is
              MIT-licensed. Content is stored as Markdown and is editable by anyone.
            </p>
            <a class="provenance" href={sourceUrl} target="_blank" rel="noreferrer">
              <span>View page source · <span class="mono">{source}</span></span>
            </a>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
